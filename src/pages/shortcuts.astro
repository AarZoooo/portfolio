---
import BaseLayout from '@layouts/BaseLayout.astro'

import Navbar from '@design/chrome/Navbar/Navbar'
import Footer from '@design/chrome/Footer/Footer'
import CustomCursor from '@design/chrome/CustomCursor/CustomCursor'
import Shortcuts from '@design/chrome/Shortcuts'

import data from '@features/portfolio/data/data.json'
import type { PortfolioData } from '@type/portfolio'
import { SUB_APPS } from '@utils/navigation'
import { withBuildDate } from '@utils/buildInfo'

const d = data as PortfolioData

interface Shortcut {
    keys: string[]
    description: string
}

interface Group {
    title: string
    note?: string
    shortcuts: Shortcut[]
}

const groups: Group[] = [
    {
        title: 'Modes',
        shortcuts: [
            { keys: ['t'], description: 'Toggle theme (light / dark)' },
            { keys: ['p'], description: 'Toggle paper mode' },
            { keys: ['w'], description: 'Toggle narrow reading column' },
        ],
    },
    {
        title: 'Navigation',
        note: 'Vim-style. Section jumps (j / k) only on the portfolio.',
        shortcuts: [
            { keys: ['g', 'g'], description: 'Scroll to top' },
            { keys: ['G'], description: 'Scroll to bottom' },
            { keys: ['j'], description: 'Next section' },
            { keys: ['k'], description: 'Previous section' },
            { keys: ['d'], description: 'Half viewport down' },
            { keys: ['u'], description: 'Half viewport up' },
            { keys: ['H'], description: 'Jump to 25% of the page' },
            { keys: ['M'], description: 'Jump to 50% of the page' },
            { keys: ['L'], description: 'Jump to 75% of the page' },
        ],
    },
]
---

<BaseLayout
    title="Keyboard shortcuts · aarju.dev"
    description="Vim-flavored keybinds for navigating aarju.dev."
    defaultWidth="narrow"
>
    <CustomCursor client:idle />

    <Navbar currentPath={Astro.url.pathname} subApps={SUB_APPS} client:load />

    <main id="main" class="container">
        <section class="page">
            <header class="head">
                <p class="kicker">Reference</p>
                <h1 class="title">Keyboard shortcuts</h1>
                <p class="lede">
                    Try them now. Inputs and modifier keys (⌘ / Ctrl / Alt) are
                    always ignored, so they won't fire while typing.
                </p>
                <p class="touch-note">
                    On touch devices, use the navbar to switch theme.
                    Long-press the logo for paper mode.
                </p>
            </header>

            {groups.map((group) => (
                <section class="group">
                    <h2 class="group-title">{group.title}</h2>
                    {group.note && <p class="group-note">{group.note}</p>}
                    <dl class="list">
                        {group.shortcuts.map((s) => (
                            <div class="row">
                                <dt class="keys">
                                    {s.keys.map((k, i) => (
                                        <>
                                            {i > 0 && <span class="join" aria-hidden="true">then</span>}
                                            <kbd class="key">{k}</kbd>
                                        </>
                                    ))}
                                </dt>
                                <dd class="action">{s.description}</dd>
                            </div>
                        ))}
                    </dl>
                </section>
            ))}
        </section>
    </main>

    <Footer footer={withBuildDate(d.footer)} client:idle />

    <Shortcuts client:idle />
</BaseLayout>

<style>
    .page {
        padding: var(--space-24) 0;
    }

    .head {
        margin-bottom: var(--space-16);
    }

    .kicker {
        margin: 0 0 var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--weight-light);
        letter-spacing: var(--tracking-wide);
        color: var(--text-muted);
        text-transform: uppercase;
    }

    .title {
        margin: 0 0 var(--space-5);
        font-family: var(--font-sans);
        font-size: var(--text-3xl);
        font-weight: var(--weight-medium);
        line-height: var(--leading-tight);
        color: var(--text);
    }

    .lede {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--text-md);
        font-weight: var(--weight-light);
        color: var(--text-secondary);
        line-height: var(--leading-snug);
    }

    /* Touch note — kept on all viewports because tablets are wide AND touch,
       so a media gate would miss them. Subtle enough to ignore on desktop. */
    .touch-note {
        margin: var(--space-5) 0 0;
        padding: var(--space-3) var(--space-4);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        line-height: var(--leading-relaxed);
        color: var(--text-muted);
        background: rgb(var(--ink) / 0.04);
        border-left: 2px solid rgb(var(--ink) / 0.15);
        border-radius: var(--radius-sm);
    }

    .group {
        margin-top: var(--space-12);
    }

    .group-title {
        margin: 0 0 var(--space-2);
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: var(--weight-medium);
        color: var(--text);
    }

    .group-note {
        margin: 0 0 var(--space-6);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .list {
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .row {
        display: grid;
        grid-template-columns: 160px 1fr;
        align-items: center;
        gap: var(--space-6);
        padding: var(--space-3) 0;
        border-bottom: var(--border-hairline) solid rgb(var(--ink) / 0.06);
    }

    .row:last-child {
        border-bottom: none;
    }

    .keys {
        margin: 0;
        display: inline-flex;
        align-items: baseline;
        gap: var(--space-2);
    }

    /* Hand-rolled keycap. Subtle border + tinted surface, mono glyph. */
    .key {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: var(--space-7);
        padding: 0 var(--space-2);
        height: var(--space-7);
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        color: var(--text);
        background: rgb(var(--ink) / 0.04);
        border: var(--border-hairline) solid rgb(var(--ink) / 0.18);
        border-bottom-width: 2px;
        border-radius: var(--radius-sm);
    }

    .join {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .action {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: var(--weight-light);
        color: var(--text-secondary);
        line-height: var(--leading-snug);
    }

    @media (max-width: 700px) {
        .row {
            grid-template-columns: minmax(0, 140px) 1fr;
            gap: var(--space-4);
        }
    }
</style>
