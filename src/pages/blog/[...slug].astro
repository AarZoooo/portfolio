---
import { getCollection, render } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import BaseLayout from '@layouts/BaseLayout.astro'

import Navbar from '@design/chrome/Navbar/Navbar'
import Footer from '@design/chrome/Footer/Footer'
import CustomCursor from '@design/chrome/CustomCursor/CustomCursor'
import Shortcuts from '@design/chrome/Shortcuts'

import data from '@features/portfolio/data/data.json'
import type { PortfolioData } from '@type/portfolio'
import { SUB_APPS } from '@utils/navigation'
import { withBuildDate } from '@utils/buildInfo'
import '@design/typography/prose.css'

const d = data as PortfolioData

export const getStaticPaths = (async () => {
    const posts = await getCollection('blog')
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }))
}) satisfies GetStaticPaths

const { post } = Astro.props
const { Content, headings } = await render(post)

// TOC: h2 + h3 only. Show only when the post has enough structure to benefit
// from one (< 3 headings makes a TOC noisier than the post itself).
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)
const hasToc = tocHeadings.length >= 3

const formatDate = (date: Date): string =>
    date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout
    title={`${post.data.title} — aarju.dev`}
    description={post.data.description}
    article={{
        publishedTime: post.data.pubDate.toISOString(),
        modifiedTime: post.data.updatedDate?.toISOString(),
        tags: post.data.tags,
    }}
    defaultWidth="narrow"
>
    <CustomCursor client:idle />

    <Navbar currentPath={Astro.url.pathname} subApps={SUB_APPS} client:load />

    <main id="main" class:list={['post-page', { 'post-page--with-toc': hasToc }]}>
        <header class="post-header">
            <time datetime={post.data.pubDate.toISOString()} class="post-date">
                {formatDate(post.data.pubDate)}
            </time>
            <h1 class="post-title">{post.data.title}</h1>
            <p class="post-lede">{post.data.description}</p>
        </header>

        {hasToc && (
            <aside class="post-toc-wrap" aria-labelledby="toc-heading">
                <details class="post-toc-details">
                    <summary id="toc-heading">Contents</summary>
                    <nav class="post-toc">
                        <ol>
                            {tocHeadings.map((h) => (
                                <li class:list={['toc-item', { 'toc-item--sub': h.depth === 3 }]}>
                                    <a href={`#${h.slug}`} data-toc-link={h.slug}>
                                        <span class="toc-dash" aria-hidden="true"></span>
                                        <span class="toc-text">{h.text}</span>
                                    </a>
                                </li>
                            ))}
                        </ol>
                    </nav>
                </details>
            </aside>
        )}

        <article class="post">
            <div class="prose">
                <Content />
            </div>
        </article>
    </main>

    <Footer footer={withBuildDate(d.footer)} client:idle />

    <Shortcuts client:idle />
</BaseLayout>

<script>
    import { smoothScrollToId, easeInOutCubic } from '@utils/smoothScroll'
    import { attachClickCopyDelegation } from '@utils/copy'
    import { copyIconHTML, checkIconHTML } from '@design/primitives/icons/icons'

    // Smooth-scroll any in-prose heading anchor (rehype-autolink-headings
    // wraps each heading in an <a class="heading-anchor" href="#slug">).
    document.querySelectorAll<HTMLAnchorElement>('.prose .heading-anchor').forEach((link) => {
        link.addEventListener('click', (e) => {
            const href = link.getAttribute('href')
            if (!href || !href.startsWith('#')) return
            e.preventDefault()
            const slug = href.slice(1)
            smoothScrollToId(slug)
            history.replaceState(null, '', href)
        })
    })

    // TOC active-section highlight. Mark the link whose heading is currently
    // most visible in the viewport. Fires only when a TOC is present.
    const tocNav = document.querySelector<HTMLElement>('.post-toc')
    if (tocNav) {
        const linksBySlug = new Map<string, HTMLAnchorElement>()
        tocNav.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]').forEach((a) => {
            const slug = a.dataset.tocLink
            if (slug) linksBySlug.set(slug, a)
        })

        // Smooth-scroll on TOC click, matching the portfolio nav motion.
        linksBySlug.forEach((link, slug) => {
            link.addEventListener('click', (e) => {
                e.preventDefault()
                smoothScrollToId(slug)
                // Reflect the anchor in the URL without triggering a jump.
                history.replaceState(null, '', `#${slug}`)
            })
        })

        const visible = new Set<string>()

        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    const id = entry.target.id
                    if (entry.isIntersecting) visible.add(id)
                    else visible.delete(id)
                }
                // Pick the topmost visible heading. Fall back to last seen.
                let active: string | null = null
                for (const slug of linksBySlug.keys()) {
                    if (visible.has(slug)) {
                        active = slug
                        break
                    }
                }
                linksBySlug.forEach((link, slug) => {
                    link.toggleAttribute('data-active', slug === active)
                })
            },
            { rootMargin: '-15% 0px -70% 0px' },
        )

        linksBySlug.forEach((_, slug) => {
            const target = document.getElementById(slug)
            if (target) observer.observe(target)
        })
    }

    // Animate the Contents <details> open/close. Native toggle is abrupt;
    // we hijack the click, measure heights, and animate via RAF using the
    // same easing curve as smoothScrollToId for site-wide consistency.
    const details = document.querySelector<HTMLDetailsElement>('.post-toc-details')
    const summary = details?.querySelector<HTMLElement>('summary')
    if (details && summary) {
        // Wide layout shows the TOC list directly (no disclosure UI).
        // <details> content is browser-hidden unless [open], so force it
        // on at this breakpoint and follow viewport changes.
        const wideMql = window.matchMedia('(min-width: 1025px)')
        const syncWideOpen = () => {
            if (wideMql.matches) details.setAttribute('open', '')
        }
        syncWideOpen()
        wideMql.addEventListener('change', syncWideOpen)

        const ANIM_MS = 280
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        let animating = false

        const animate = (from: number, to: number, onDone: () => void) => {
            if (reduced) {
                onDone()
                return
            }
            animating = true
            const start = performance.now()
            const step = (now: number) => {
                const p = Math.min((now - start) / ANIM_MS, 1)
                const h = from + (to - from) * easeInOutCubic(p)
                details.style.height = `${h}px`
                if (p < 1) requestAnimationFrame(step)
                else {
                    details.style.height = ''
                    details.style.overflow = ''
                    animating = false
                    onDone()
                }
            }
            details.style.overflow = 'hidden'
            requestAnimationFrame(step)
        }

        summary.addEventListener('click', (e) => {
            e.preventDefault()
            if (animating) return
            const closed = !details.hasAttribute('open')
            if (closed) {
                // Opening: temporarily open, measure full height, animate from
                // collapsed (summary only) → full.
                const collapsed = summary.offsetHeight
                details.setAttribute('open', '')
                const full = details.offsetHeight
                details.style.height = `${collapsed}px`
                requestAnimationFrame(() => animate(collapsed, full, () => {}))
            } else {
                // Closing: snapshot full height, animate down to summary height,
                // then remove [open] attribute.
                const full = details.offsetHeight
                const collapsed = summary.offsetHeight
                animate(full, collapsed, () => {
                    details.removeAttribute('open')
                })
            }
        })
    }

    // Inject [data-copy] copy buttons onto every code block. The actual
    // click handling (clipboard write + animation) is owned by the shared
    // copy delegation below — these buttons just expose the contract.
    document.querySelectorAll<HTMLElement>('.prose pre').forEach((pre) => {
        if (pre.querySelector('.code-copy')) return
        const code = pre.querySelector('code')?.textContent ?? ''
        const button = document.createElement('button')
        button.type = 'button'
        button.className = 'code-copy'
        button.setAttribute('aria-label', 'Copy code to clipboard')
        button.setAttribute('data-copy', code)
        button.innerHTML = copyIconHTML() + checkIconHTML()
        pre.appendChild(button)
    })

    attachClickCopyDelegation()
</script>

<style>
    @import '@design/tokens/breakpoints.css';

    /* Default: single-column, mirrors .container behavior. */
    .post-page {
        width: 100%;
        max-width: var(--content-max);
        margin: 0 auto;
        padding-inline: var(--content-gutter);
        padding-top: var(--space-24);
    }

    /* Headings get scroll-margin so direct anchor loads (e.g. #slug from
       URL) clear the fixed navbar. JS-driven smoothScrollToId uses its
       own offset, so this only kicks in for native hash navigation. */
    .prose :is(h2, h3, h4) {
        scroll-margin-top: calc(var(--space-16) + var(--space-4));
    }

    /* Header took the article's old top padding; reset .post since it no
       longer needs a clearance from the navbar. */
    .post-page > .post {
        padding: 0;
    }

    /* TOC layout: kicks in only above the medium breakpoint. Below that,
       the TOC renders as a collapsed <details> below header, above body. */
    @media (min-width: 1025px) {
        .post-page--with-toc {
            display: grid;
            max-width: var(--content-max-wide);
            grid-template-columns: 200px minmax(0, var(--content-max)) 1fr;
            grid-template-areas:
                "toc header ."
                "toc body   .";
            column-gap: var(--space-8);
            align-items: start;
        }

        .post-page--with-toc .post-header {
            grid-area: header;
        }
        .post-page--with-toc .post {
            grid-area: body;
        }
        .post-page--with-toc .post-toc-wrap {
            grid-area: toc;
            position: sticky;
            top: calc(var(--space-16) + var(--space-12));
            align-self: start;
        }

        /* On wide screens, drop the disclosure UI — show the list directly. */
        .post-page--with-toc .post-toc-details {
            list-style: none;
        }
        .post-page--with-toc .post-toc-details > summary {
            display: none;
        }
        .post-page--with-toc .post-toc-details[open],
        .post-page--with-toc .post-toc-details {
            /* Force open visually regardless of the user's mobile-toggle state. */
        }
        .post-page--with-toc .post-toc {
            display: block !important;
        }
    }

    /* Mobile: <details> collapsed by default. */
    @media (--bp-medium) {
        .post-toc-wrap {
            margin-bottom: var(--space-8);
        }

        .post-toc-details > summary {
            cursor: pointer;
            font-family: var(--font-mono);
            font-size: var(--text-xs);
            font-weight: var(--weight-medium);
            letter-spacing: var(--tracking-wide);
            color: var(--text-muted);
            text-transform: uppercase;
            list-style: none;
            padding: var(--space-2) 0;
            transition: color var(--duration-base) ease;
        }
        .post-toc-details > summary:hover {
            color: var(--text);
        }
        .post-toc-details > summary::-webkit-details-marker {
            display: none;
        }
        .post-toc-details > summary::before {
            content: '+';
            display: inline-block;
            margin-right: 0.4em;
            transition: transform var(--duration-base) ease;
        }
        .post-toc-details > summary:hover::before {
            transform: scale(1.25);
        }
        .post-toc-details[open] > summary::before {
            content: '−';
        }

        .post-toc {
            margin-top: var(--space-3);
        }
    }

    /* TOC list itself */
    .post-toc {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        line-height: var(--leading-relaxed);
    }

    .post-toc ol {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .toc-item {
        margin: var(--space-1) 0;
    }

    .toc-item--sub {
        padding-left: var(--space-4);
    }

    .post-toc a {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--duration-base) ease;
    }

    .post-toc a:hover,
    .post-toc a[data-active] {
        color: var(--text);
    }

    /* Solid hairline. Hyphen-sized by default; shrinks on hover/active so
       the section name visually steps forward. Color goes full on activate. */
    .toc-dash {
        flex-shrink: 0;
        height: 1px;
        width: var(--space-2);
        background: currentColor;
        opacity: 0.5;
        transition:
            width var(--duration-base) ease,
            opacity var(--duration-base) ease;
    }

    .post-toc a:hover .toc-dash,
    .post-toc a[data-active] .toc-dash {
        width: var(--space-1);
        opacity: 1;
    }

    .toc-text {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .post-header {
        margin-bottom: var(--space-12);
    }

    .post-date {
        display: block;
        margin-bottom: var(--space-3);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: var(--weight-light);
        letter-spacing: var(--tracking-wide);
        color: var(--text-muted);
        text-transform: uppercase;
    }

    .post-title {
        margin: 0 0 var(--space-5);
        font-family: var(--font-sans);
        font-size: var(--text-3xl);
        font-weight: var(--weight-medium);
        line-height: var(--leading-tight);
        color: var(--text);
    }

    .post-lede {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--text-md);
        font-weight: var(--weight-light);
        color: var(--text-secondary);
        line-height: var(--leading-snug);
    }
</style>
