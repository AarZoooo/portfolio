---
import BaseLayout from '@layouts/BaseLayout.astro'

import Navbar from '@design/chrome/Navbar/Navbar'
import Footer from '@design/chrome/Footer/Footer'
import CustomCursor from '@design/chrome/CustomCursor/CustomCursor'
import Shortcuts from '@design/chrome/Shortcuts'

import Hero from '@features/portfolio/sections/Hero/Hero'
import Experience from '@features/portfolio/sections/Experience/Experience'
import Skills from '@features/portfolio/sections/Skills/Skills'
import Projects from '@features/portfolio/sections/Projects/Projects'
import Education from '@features/portfolio/sections/Education/Education'
import Contact from '@features/portfolio/sections/Contact/Contact'

import data from '@features/portfolio/data/data.json'
import type { PortfolioData } from '@type/portfolio'
import { SUB_APPS } from '@utils/navigation'

const d = data as PortfolioData

// Stable at module scope so Navbar effects do not re-bind per render.
const SECTION_LINKS = [
    { id: 'experience', label: d.sections.experience, short: 'exp' },
    { id: 'skills', label: d.sections.skills, short: 'skl' },
    { id: 'projects', label: d.sections.projects, short: 'prj' },
    { id: 'education', label: d.sections.education, short: 'edu' },
    { id: 'contact', label: d.sections.contact, short: 'ctc' },
]
---

<BaseLayout title={`Portfolio: ${d.personal.name}`} description={d.personal.summary}>
    <CustomCursor client:idle />

    <Navbar
        currentPath={Astro.url.pathname}
        sectionLinks={SECTION_LINKS}
        subApps={SUB_APPS}
        client:load
    />

    <main id="main" class="container">
        <Hero personal={d.personal} hero={d.hero} client:load />
        <Experience heading={d.sections.experience} items={d.experience} client:visible />
        <Skills heading={d.sections.skills} skills={d.skills} />
        <Projects heading={d.sections.projects} items={d.projects} client:visible />
        <Education heading={d.sections.education} items={d.education} />
        <Contact heading={d.sections.contact} personal={d.personal} />
    </main>

    <Footer footer={d.footer} client:idle />

    <Shortcuts client:idle />
</BaseLayout>

<script>
    // Click-to-copy on Contact section values. Uses document-level event
    // delegation so HMR / late React renders don't strand listeners.
    // Falls back to execCommand when navigator.clipboard is unavailable
    // or rejects (insecure context, document not focused, etc.).
    const COPY_FEEDBACK_MS = 1500

    async function copyText(text: string): Promise<boolean> {
        try {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(text)
                return true
            }
        } catch {
            // fall through to legacy path
        }
        // Legacy fallback: an off-screen textarea + execCommand. Loud but reliable.
        const ta = document.createElement('textarea')
        ta.value = text
        ta.setAttribute('readonly', '')
        ta.style.position = 'fixed'
        ta.style.opacity = '0'
        document.body.appendChild(ta)
        ta.select()
        let ok = false
        try {
            ok = document.execCommand('copy')
        } catch {
            ok = false
        }
        document.body.removeChild(ta)
        return ok
    }

    // CSS reads --duration-medium (280ms) for the tail-out fade. We hold
    // the [data-copied] flag for COPY_FEEDBACK_MS, then add [data-fading]
    // so the whole button fades out *while still showing the check*, and
    // only after the fade do we strip both flags and reset.
    const COPY_FADE_MS = 280

    document.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>(
            'button[data-copy]',
        )
        if (!btn) return
        const text = btn.dataset.copy
        if (!text) return
        const ok = await copyText(text)
        if (!ok) return
        btn.setAttribute('data-copied', '')
        window.setTimeout(() => {
            btn.setAttribute('data-fading', '')
            window.setTimeout(() => {
                btn.removeAttribute('data-copied')
                btn.removeAttribute('data-fading')
            }, COPY_FADE_MS)
        }, COPY_FEEDBACK_MS)
    })
</script>
