---
// Phase 2a: minimal placeholder so the dev server has something to render
// during the migration. Replaced wholesale in Phase 2d when the real
// portfolio comes online via BaseLayout + section components.
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>aarju.dev — migrating</title>
        <style is:global>
            html,
            body {
                margin: 0;
                font-family: ui-monospace, "SF Mono", Menlo, monospace;
                background: #f7f7f5;
                color: #1a1a1a;
                min-height: 100vh;
                display: grid;
                place-items: center;
            }
            @media (prefers-color-scheme: dark) {
                html,
                body {
                    background: #0e0e0d;
                    color: #ededed;
                }
            }
            .card {
                text-align: center;
                opacity: 0.7;
                line-height: 1.7;
            }
            .card p {
                margin: 0.25rem 0;
            }
            .card code {
                font-size: 0.85em;
                opacity: 0.7;
            }
        </style>
    </head>
    <body>
        <div class="card">
            <p>aarju.dev</p>
            <p>migrating to astro</p>
            <p><code>webapp_v2</code></p>
        </div>
    </body>
</html>
